#!/usr/bin/env bash
set -euo pipefail

# Pulls pre-built JS/CSS bundles from npm for form-js, bpmn-js, and dmn-js
# and vendors them into the Rails engine asset directories.
#
# Usage:
#   bin/get-js-bundles                            # all packages, latest
#   bin/get-js-bundles --form-js 1.10.0           # specific form-js version
#   bin/get-js-bundles --bpmn-js 18.13.1          # specific bpmn-js version
#   bin/get-js-bundles --dmn-js 17.7.0            # specific dmn-js version
#   bin/get-js-bundles --form-js latest --bpmn-js 18.13.1 --dmn-js latest

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENGINE_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

FORM_JS_VERSION="latest"
BPMN_JS_VERSION="latest"
DMN_JS_VERSION="latest"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --form-js)  FORM_JS_VERSION="$2"; shift 2 ;;
    --bpmn-js)  BPMN_JS_VERSION="$2"; shift 2 ;;
    --dmn-js)   DMN_JS_VERSION="$2"; shift 2 ;;
    *)          echo "Unknown option: $1"; exit 1 ;;
  esac
done

TMPDIR="$(mktemp -d)"
cleanup() { rm -rf "$TMPDIR"; }
trap cleanup EXIT

# ── form-js ──────────────────────────────────────────────────────────

fetch_form_js() {
  local version="$1"
  echo "==> Downloading @bpmn-io/form-js@${version}..."
  cd "$TMPDIR"
  npm pack "@bpmn-io/form-js@${version}" --silent
  tar xzf bpmn-io-form-js-*.tgz

  local actual
  actual=$(node -e "console.log(require('./package/package.json').version)")
  echo "    version: ${actual}"

  local js_dir="${ENGINE_ROOT}/app/assets/javascripts/form-js"
  local css_dir="${ENGINE_ROOT}/app/assets/stylesheets/form-js"
  mkdir -p "$js_dir" "$css_dir"

  cp package/dist/form-viewer.umd.js  "$js_dir/"
  cp package/dist/form-editor.umd.js  "$js_dir/"
  cp package/dist/assets/form-js.css  "$css_dir/"
  cp package/dist/assets/form-js-editor.css "$css_dir/"

  echo "    ${js_dir}/form-viewer.umd.js"
  echo "    ${js_dir}/form-editor.umd.js"
  echo "    ${css_dir}/form-js.css"
  echo "    ${css_dir}/form-js-editor.css"

  rm -rf package bpmn-io-form-js-*.tgz
}

# ── bpmn-js ──────────────────────────────────────────────────────────

fetch_bpmn_js() {
  local version="$1"
  echo "==> Downloading bpmn-js@${version}..."
  cd "$TMPDIR"
  npm pack "bpmn-js@${version}" --silent
  tar xzf bpmn-js-*.tgz

  local actual
  actual=$(node -e "console.log(require('./package/package.json').version)")
  echo "    version: ${actual}"

  local js_dir="${ENGINE_ROOT}/app/assets/javascripts/bpmn-js"
  local css_dir="${ENGINE_ROOT}/app/assets/stylesheets/bpmn-js"
  local font_dir="${css_dir}/bpmn-font"
  mkdir -p "$js_dir" "$css_dir" "$font_dir/css" "$font_dir/font"

  cp package/dist/bpmn-viewer.production.min.js   "$js_dir/"
  cp package/dist/bpmn-modeler.production.min.js   "$js_dir/"
  cp package/dist/assets/bpmn-js.css               "$css_dir/"
  cp package/dist/assets/diagram-js.css            "$css_dir/"
  cp -r package/dist/assets/bpmn-font/css/*        "$font_dir/css/"
  cp -r package/dist/assets/bpmn-font/font/*       "$font_dir/font/"

  echo "    ${js_dir}/bpmn-viewer.production.min.js"
  echo "    ${js_dir}/bpmn-modeler.production.min.js"
  echo "    ${css_dir}/bpmn-js.css"
  echo "    ${css_dir}/diagram-js.css"
  echo "    ${font_dir}/css/ (bpmn-embedded.css, bpmn.css, bpmn-codes.css)"
  echo "    ${font_dir}/font/ (bpmn.woff2, bpmn.woff, bpmn.ttf, bpmn.eot, bpmn.svg)"

  rm -rf package bpmn-js-*.tgz
}

# ── dmn-js ───────────────────────────────────────────────────────────

fetch_dmn_js() {
  local version="$1"
  echo "==> Downloading dmn-js@${version}..."
  cd "$TMPDIR"
  npm pack "dmn-js@${version}" --silent
  tar xzf dmn-js-*.tgz

  local actual
  actual=$(node -e "console.log(require('./package/package.json').version)")
  echo "    version: ${actual}"

  local js_dir="${ENGINE_ROOT}/app/assets/javascripts/dmn-js"
  local css_dir="${ENGINE_ROOT}/app/assets/stylesheets/dmn-js"
  local font_dir="${css_dir}/dmn-font"
  mkdir -p "$js_dir" "$css_dir" "$font_dir/css" "$font_dir/font"

  cp package/dist/dmn-viewer.production.min.js    "$js_dir/"
  cp package/dist/dmn-modeler.production.min.js   "$js_dir/"
  cp package/dist/assets/diagram-js.css                      "$css_dir/"
  cp package/dist/assets/dmn-js-shared.css                   "$css_dir/"
  cp package/dist/assets/dmn-js-drd.css                      "$css_dir/"
  cp package/dist/assets/dmn-js-decision-table.css           "$css_dir/"
  cp package/dist/assets/dmn-js-decision-table-controls.css  "$css_dir/"
  cp package/dist/assets/dmn-js-literal-expression.css       "$css_dir/"
  cp package/dist/assets/dmn-js-boxed-expression.css         "$css_dir/"
  cp package/dist/assets/dmn-js-boxed-expression-controls.css "$css_dir/"
  cp -r package/dist/assets/dmn-font/css/*        "$font_dir/css/"
  cp -r package/dist/assets/dmn-font/font/*       "$font_dir/font/"

  echo "    ${js_dir}/dmn-viewer.production.min.js"
  echo "    ${js_dir}/dmn-modeler.production.min.js"
  echo "    ${css_dir}/diagram-js.css"
  echo "    ${css_dir}/dmn-js-shared.css"
  echo "    ${css_dir}/dmn-js-drd.css"
  echo "    ${css_dir}/dmn-js-decision-table.css"
  echo "    ${css_dir}/dmn-js-decision-table-controls.css"
  echo "    ${css_dir}/dmn-js-literal-expression.css"
  echo "    ${css_dir}/dmn-js-boxed-expression.css"
  echo "    ${css_dir}/dmn-js-boxed-expression-controls.css"
  echo "    ${font_dir}/css/ (dmn-embedded.css, dmn.css, dmn-codes.css)"
  echo "    ${font_dir}/font/ (dmn.woff2, dmn.woff, dmn.ttf, dmn.eot, dmn.svg)"

  rm -rf package dmn-js-*.tgz
}

# ── run ──────────────────────────────────────────────────────────────

fetch_form_js "$FORM_JS_VERSION"
fetch_bpmn_js "$BPMN_JS_VERSION"
fetch_dmn_js "$DMN_JS_VERSION"

echo ""
echo "Done."
