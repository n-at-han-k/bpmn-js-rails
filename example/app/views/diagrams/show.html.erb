<h1><%= @diagram.name %></h1>

<% if @diagram.description.present? %>
  <p><%= @diagram.description %></p>
<% end %>

<p>
  <strong>Status:</strong> <%= @diagram.status %> |
  <strong>Version:</strong> <%= @diagram.version %>
</p>

<div id="diagram-viewer-wrapper" style="border: 1px solid #ddd; border-radius: 4px; padding: 16px; margin: 16px 0;">
  <%= bpmn_js_viewer(@diagram) %>
</div>

<p>
  <%= link_to "Edit", edit_diagram_path(@diagram) %> |
  <%= link_to "Back to diagrams", diagrams_path %>
</p>
