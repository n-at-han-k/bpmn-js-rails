<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "BPMN JS Rails Example" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= bpmn_js_assets(:viewer, :modeler, camunda_platform: true) %>
    <%= form_js_assets(:viewer, :editor) %>
    <%= dmn_js_assets(:viewer, :modeler) %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body style="font-family: sans-serif; max-width: 960px; margin: 0 auto; padding: 16px;">
    <nav style="margin-bottom: 16px; padding: 8px 0; border-bottom: 1px solid #ddd;">
      <%= link_to "Diagrams", diagrams_path %> |
      <%= link_to "Decisions", decisions_path %> |
      <%= link_to "Forms", forms_path %>
    </nav>

    <% if notice.present? %>
      <div style="padding: 12px; background: #d4edda; border: 1px solid #c3e6cb; border-radius: 4px; margin-bottom: 16px;">
        <%= notice %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
