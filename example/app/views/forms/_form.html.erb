<%= form_with(model: form, url: form.persisted? ? form_path(form) : forms_path) do |f| %>
  <% if form.errors.any? %>
    <div style="color: red; margin-bottom: 16px;">
      <h3><%= pluralize(form.errors.count, "error") %> prohibited this form from being saved:</h3>
      <ul>
        <% form.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div style="margin-bottom: 12px;">
    <%= f.label :name %>
    <%= f.text_field :name, style: "width: 100%; padding: 8px; box-sizing: border-box;" %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= f.label :description %>
    <%= f.text_area :description, rows: 3, style: "width: 100%; padding: 8px; box-sizing: border-box;" %>
  </div>

  <div style="margin-bottom: 12px;">
    <%= f.label :status %>
    <%= f.select :status, BpmnJsRails::Form::STATUSES, {}, style: "padding: 8px;" %>
  </div>

  <h3>Form Designer</h3>

  <div style="border: 1px solid #ddd; border-radius: 4px; margin-bottom: 16px;">
    <%= form_js_editor(form, field_name: "form[schema]") %>
  </div>

  <div>
    <%= f.submit style: "padding: 8px 24px; cursor: pointer;" %>
  </div>
<% end %>
