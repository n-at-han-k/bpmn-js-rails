[
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.http-connector.advanced",
    "name": "Kremlin HTTP Connector (Advanced)",
    "description": "HTTP task with grouped fields and conditional auth inputs.",
    "version": 1,
    "engines": {
      "camunda": ">=8.6"
    },
    "appliesTo": [
      "bpmn:ServiceTask"
    ],
    "groups": [
      {
        "id": "request",
        "label": "Request"
      },
      {
        "id": "auth",
        "label": "Authentication"
      },
      {
        "id": "mapping",
        "label": "Response Mapping"
      }
    ],
    "properties": [
      {
        "type": "Hidden",
        "value": "kremlin.http.request",
        "binding": {
          "type": "zeebe:taskDefinition",
          "property": "type"
        }
      },
      {
        "label": "Endpoint URL",
        "group": "request",
        "type": "String",
        "binding": {
          "type": "zeebe:taskHeader",
          "key": "url"
        },
        "constraints": {
          "notEmpty": true,
          "pattern": {
            "value": "^https?://.*",
            "message": "Must be an http(s) URL."
          }
        }
      },
      {
        "id": "httpMethod",
        "label": "Method",
        "group": "request",
        "type": "Dropdown",
        "value": "get",
        "choices": [
          { "name": "GET", "value": "get" },
          { "name": "POST", "value": "post" },
          { "name": "PATCH", "value": "patch" },
          { "name": "DELETE", "value": "delete" }
        ],
        "binding": {
          "type": "zeebe:taskHeader",
          "key": "method"
        }
      },
      {
        "label": "Request Body",
        "group": "request",
        "type": "Text",
        "optional": true,
        "feel": "optional",
        "binding": {
          "type": "zeebe:input",
          "name": "body"
        },
        "condition": {
          "property": "httpMethod",
          "oneOf": [
            "post",
            "patch",
            "delete"
          ]
        }
      },
      {
        "id": "authType",
        "label": "Authentication",
        "group": "auth",
        "type": "Dropdown",
        "value": "none",
        "choices": [
          { "name": "None", "value": "none" },
          { "name": "Basic", "value": "basic" },
          { "name": "Bearer", "value": "bearer" }
        ],
        "binding": {
          "type": "zeebe:input",
          "name": "authentication.type"
        }
      },
      {
        "label": "Username",
        "group": "auth",
        "type": "String",
        "optional": true,
        "binding": {
          "type": "zeebe:input",
          "name": "authentication.username"
        },
        "condition": {
          "property": "authType",
          "equals": "basic"
        }
      },
      {
        "label": "Password",
        "group": "auth",
        "type": "String",
        "optional": true,
        "binding": {
          "type": "zeebe:input",
          "name": "authentication.password"
        },
        "condition": {
          "property": "authType",
          "equals": "basic"
        }
      },
      {
        "label": "Bearer Token",
        "group": "auth",
        "type": "String",
        "optional": true,
        "feel": "optional",
        "binding": {
          "type": "zeebe:input",
          "name": "authentication.token"
        },
        "condition": {
          "property": "authType",
          "equals": "bearer"
        }
      },
      {
        "label": "Response Variable",
        "group": "mapping",
        "type": "String",
        "value": "httpResponse",
        "optional": true,
        "binding": {
          "type": "zeebe:output",
          "source": "= body"
        }
      }
    ]
  },
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.policy.retry-and-timeout",
    "name": "Kremlin Retry + Timeout Policy",
    "description": "Demonstrates Number/Boolean controls and FEEL modes.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:ServiceTask"
    ],
    "properties": [
      {
        "label": "Retry Count",
        "type": "Number",
        "value": "3",
        "feel": "static",
        "binding": {
          "type": "zeebe:property",
          "name": "retryCount"
        }
      },
      {
        "label": "Retry Backoff (seconds)",
        "type": "Number",
        "value": "30",
        "feel": "optional",
        "binding": {
          "type": "zeebe:property",
          "name": "retryBackoffSeconds"
        }
      },
      {
        "id": "enableTimeout",
        "label": "Enable timeout",
        "type": "Boolean",
        "value": true,
        "feel": "static",
        "binding": {
          "type": "zeebe:property",
          "name": "enableTimeout"
        }
      },
      {
        "label": "Timeout (ISO-8601)",
        "type": "String",
        "value": "PT2M",
        "binding": {
          "type": "zeebe:taskHeader",
          "key": "timeout"
        },
        "condition": {
          "property": "enableTimeout",
          "equals": true
        }
      }
    ]
  },
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.event.conditional",
    "name": "Kremlin Conditional Event",
    "description": "Turns a generic event into an intermediate conditional catch event.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:Event"
    ],
    "elementType": {
      "value": "bpmn:IntermediateCatchEvent",
      "eventDefinition": "bpmn:ConditionalEventDefinition"
    },
    "properties": [
      {
        "label": "Condition Expression",
        "type": "String",
        "value": "= total > threshold",
        "feel": "required",
        "binding": {
          "type": "bpmn:ConditionalEventDefinition#property",
          "name": "condition"
        }
      },
      {
        "label": "Variable Names",
        "type": "String",
        "value": "total,threshold",
        "binding": {
          "type": "bpmn:ConditionalEventDefinition#zeebe:conditionalFilter#property",
          "name": "variableNames"
        }
      },
      {
        "label": "Variable Events",
        "type": "String",
        "value": "create,update",
        "binding": {
          "type": "bpmn:ConditionalEventDefinition#zeebe:conditionalFilter#property",
          "name": "variableEvents"
        }
      }
    ]
  }
]
