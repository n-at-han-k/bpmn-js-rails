[
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.http-worker",
    "name": "Kremlin HTTP Worker",
    "description": "Run a generic HTTP worker job with mapped request settings.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:ServiceTask"
    ],
    "groups": [
      {
        "id": "job",
        "label": "Job"
      },
      {
        "id": "request",
        "label": "Request"
      }
    ],
    "properties": [
      {
        "label": "Job type",
        "description": "Zeebe worker type consumed by your worker process.",
        "group": "job",
        "type": "String",
        "value": "kremlin.http.request",
        "binding": {
          "type": "zeebe:taskDefinition",
          "property": "type"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Retries",
        "group": "job",
        "type": "String",
        "value": "3",
        "binding": {
          "type": "zeebe:taskDefinition",
          "property": "retries"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Method",
        "description": "HTTP verb sent by the worker.",
        "group": "request",
        "type": "Dropdown",
        "value": "GET",
        "choices": [
          {
            "name": "GET",
            "value": "GET"
          },
          {
            "name": "POST",
            "value": "POST"
          },
          {
            "name": "PUT",
            "value": "PUT"
          },
          {
            "name": "PATCH",
            "value": "PATCH"
          },
          {
            "name": "DELETE",
            "value": "DELETE"
          }
        ],
        "binding": {
          "type": "zeebe:input",
          "name": "method"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Endpoint",
        "description": "Absolute URL or FEEL expression resolved by the worker.",
        "group": "request",
        "type": "String",
        "feel": "optional",
        "binding": {
          "type": "zeebe:input",
          "name": "url"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Body",
        "description": "Optional payload for non-GET methods.",
        "group": "request",
        "type": "Text",
        "feel": "optional",
        "optional": true,
        "binding": {
          "type": "zeebe:input",
          "name": "body"
        }
      }
    ]
  },
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.notify-email",
    "name": "Kremlin Email Notification",
    "description": "Send an email through an external worker.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:ServiceTask"
    ],
    "properties": [
      {
        "type": "Hidden",
        "value": "kremlin.notify.email",
        "binding": {
          "type": "zeebe:taskDefinition",
          "property": "type"
        }
      },
      {
        "label": "To",
        "type": "String",
        "binding": {
          "type": "zeebe:input",
          "name": "to"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Subject",
        "type": "String",
        "binding": {
          "type": "zeebe:input",
          "name": "subject"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "Body",
        "type": "Text",
        "binding": {
          "type": "zeebe:input",
          "name": "body"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "label": "CC",
        "description": "Optional comma-separated recipient list.",
        "type": "String",
        "optional": true,
        "binding": {
          "type": "zeebe:input",
          "name": "cc"
        }
      }
    ]
  },
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.user-task-form",
    "name": "Kremlin User Task Form",
    "description": "Attach a generated form id to a user task.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:UserTask"
    ],
    "properties": [
      {
        "label": "Form ID",
        "description": "Camunda form id deployed with this process.",
        "type": "String",
        "binding": {
          "type": "zeebe:formDefinition",
          "property": "formId"
        },
        "constraints": {
          "notEmpty": true
        }
      }
    ]
  },
  {
    "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
    "id": "io.kremlin.call-process",
    "name": "Kremlin Call Activity",
    "description": "Call another process definition with explicit variable propagation.",
    "version": 1,
    "engines": {
      "camunda": "^8.6"
    },
    "appliesTo": [
      "bpmn:CallActivity"
    ],
    "properties": [
      {
        "label": "Process ID",
        "type": "String",
        "binding": {
          "type": "zeebe:calledElement",
          "property": "processId"
        },
        "constraints": {
          "notEmpty": true
        }
      },
      {
        "type": "Hidden",
        "value": "latest",
        "binding": {
          "type": "zeebe:calledElement",
          "property": "bindingType"
        }
      },
      {
        "label": "Inherit all parent variables",
        "type": "Boolean",
        "value": true,
        "binding": {
          "type": "zeebe:calledElement",
          "property": "propagateAllParentVariables"
        }
      },
      {
        "label": "Propagate all child variables",
        "type": "Boolean",
        "value": true,
        "binding": {
          "type": "zeebe:calledElement",
          "property": "propagateAllChildVariables"
        }
      }
    ]
  }
]
