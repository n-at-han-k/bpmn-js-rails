{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Grouping",
  "id": "example.com.grouping",
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "properties": [
    {
      "type": "String",
      "value": "http",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "label": "REST Endpoint URL",
      "group": "headers",
      "type": "String",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "url"
      }
    },
    {
      "label": "REST Method",
      "group": "headers",
      "type": "Dropdown",
      "value": "get",
      "choices": [
        {
          "name": "GET",
          "value": "get"
        },
        {
          "name": "POST",
          "value": "post"
        },
        {
          "name": "PATCH",
          "value": "patch"
        },
        {
          "name": "DELETE",
          "value": "delete"
        }
      ],
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "method"
      }
    },
    {
      "label": "Request Body",
      "value": "",
      "group": "payload",
      "type": "String",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      }
    },
    {
      "label": "Result Variable",
      "group": "mapping",
      "value": "response",
      "type": "String",
      "binding": {
        "type": "zeebe:output",
        "source": "= body"
      }
    }
  ],
  "groups": [
    {
      "id": "headers",
      "label": "Request headers"
    },
    {
      "id": "payload",
      "label": "Request payload"
    },
    {
      "id": "mapping",
      "label": "Response mapping"
    }
  ]
}
