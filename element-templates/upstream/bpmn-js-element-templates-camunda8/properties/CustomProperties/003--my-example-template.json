{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Task Template",
  "id": "my.example.template",
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "type": "String",
      "value": "my Task",
