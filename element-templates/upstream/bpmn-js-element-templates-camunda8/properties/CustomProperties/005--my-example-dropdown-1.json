{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Task Template 3",
  "id": "my.example.dropdown-1",
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "properties": [
    {
      "label": "No Value Input",
      "type": "Dropdown",
      "choices": [
        {
          "name": "low",
          "value": "low"
        },
        {
          "name": "medium",
          "value": "medium"
        },
        {
          "name": "high",
          "value": "high"
        }
      ],
      "binding": {
        "type": "zeebe:input",
        "name": "noValueInput"
      }
    }
  ]
}
