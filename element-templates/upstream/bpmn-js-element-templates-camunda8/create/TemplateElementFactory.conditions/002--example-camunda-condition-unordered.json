{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Condition - unorderd",
  "id": "example.camunda.condition.unordered",
  "description": "A conditional template.",
  "appliesTo": [
    "bpmn:Task"
  ],
  "properties": [
    {
      "id": "property1",
      "label": "depends on property2",
      "type": "String",
      "value": "bar",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      },
      "condition": {
        "property": "property2",
        "equals": "foo"
      }
    },
    {
      "id": "property2",
      "label": "depends on property1",
      "type": "String",
      "value": "foo",
      "binding": {
        "type": "zeebe:input",
        "name": "body"
      },
      "condition": {
        "property": "property3",
        "equals": "bar"
      }
    },
    {
      "id": "property3",
      "label": "depends on property4",
      "type": "String",
      "value": "bar",
      "binding": {
        "type": "zeebe:output",
        "source": "= body"
      },
      "condition": {
        "property": "property4",
        "equals": "foo"
      }
    },
    {
      "id": "property4",
      "label": "depends on property5",
      "type": "String",
      "value": "foo",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "someKey"
      },
      "condition": {
        "property": "property5",
        "equals": "bar"
      }
    },
    {
      "id": "property5",
      "label": "depends on property6",
      "type": "String",
      "value": "bar",
      "binding": {
        "type": "zeebe:property",
        "name": "someName"
      },
      "condition": {
        "property": "property6",
        "equals": "foo"
      }
    },
    {
      "id": "property6",
      "label": "name",
      "type": "String",
      "value": "foo",
      "binding": {
        "type": "property",
        "name": "name"
      }
    }
  ]
}
