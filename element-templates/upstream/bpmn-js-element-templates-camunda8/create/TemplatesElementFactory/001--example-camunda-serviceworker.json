{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Service worker",
  "id": "example.camunda.ServiceWorker",
  "version": 1,
  "appliesTo": [
    "bpmn:ServiceTask"
  ],
  "properties": [
    {
      "value": "name",
      "binding": {
        "type": "property",
        "name": "name"
      }
    },
    {
      "value": "job-type",
      "binding": {
        "type": "zeebe:taskDefinition:type"
      }
    },
    {
      "value": "header-1-value",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "header-1"
      }
    },
    {
      "value": "header-2-value",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "header-2"
      }
    },
    {
      "value": "input-1-value",
      "binding": {
        "type": "zeebe:input",
        "name": "input-1"
      }
    },
    {
      "value": "input-2-value",
      "binding": {
        "type": "zeebe:input",
        "name": "input-2"
      }
    },
    {
      "value": "output-1-value",
      "binding": {
        "type": "zeebe:output",
        "source": "output-1"
      }
    },
    {
      "value": "output-2-value",
      "binding": {
        "type": "zeebe:output",
        "source": "output-2"
      }
    }
  ]
}
