{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Execution Listeners Template",
  "id": "example.camunda.ExecutionListenersBinding",
  "appliesTo": [
    "bpmn:Task"
  ],
  "entriesVisible": {
    "executionListeners": false
  },
  "properties": [
    {
      "type": "Hidden",
      "value": "=on-start-handler",
      "binding": {
        "type": "zeebe:executionListener",
        "eventType": "start"
      }
    },
    {
      "type": "Hidden",
      "value": "=on-end-handler",
      "binding": {
        "type": "zeebe:executionListener",
        "eventType": "end",
        "retries": "=3"
      }
    }
  ]
}
