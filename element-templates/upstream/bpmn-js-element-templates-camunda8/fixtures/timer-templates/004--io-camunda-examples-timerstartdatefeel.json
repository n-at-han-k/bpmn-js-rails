{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Timer Start Event - Date (FEEL)",
  "id": "io.camunda.examples.TimerStartDateFeel",
  "version": 1,
  "description": "A timer start event with a FEEL expression for the date",
  "appliesTo": [
    "bpmn:StartEvent"
  ],
  "elementType": {
    "value": "bpmn:StartEvent",
    "eventDefinition": "bpmn:TimerEventDefinition"
  },
  "icon": {
    "contents": "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath fill='%23ff6600' d='M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z'/%3E%3C/svg%3E"
  },
  "properties": [
    {
      "id": "dateExpression",
      "label": "Date Expression (FEEL)",
      "description": "A FEEL expression that evaluates to a date-time",
      "type": "String",
      "feel": "required",
      "value": "now() + duration(\"P7D\")",
      "binding": {
        "type": "bpmn:TimerEventDefinition#property",
        "name": "timeDate"
      }
    }
  ]
}
