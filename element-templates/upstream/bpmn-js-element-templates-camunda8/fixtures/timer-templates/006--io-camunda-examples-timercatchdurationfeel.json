{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Timer Catch Event - Duration (FEEL)",
  "id": "io.camunda.examples.TimerCatchDurationFeel",
  "version": 1,
  "description": "A timer intermediate catch event with a FEEL expression for duration",
  "appliesTo": [
    "bpmn:IntermediateCatchEvent"
  ],
  "elementType": {
    "value": "bpmn:IntermediateCatchEvent",
    "eventDefinition": "bpmn:TimerEventDefinition"
  },
  "icon": {
    "contents": "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Cpath fill='%2300aa00' d='M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.02 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z'/%3E%3C/svg%3E"
  },
  "properties": [
    {
      "id": "durationExpression",
      "label": "Duration Expression (FEEL)",
      "description": "A FEEL expression that evaluates to a duration",
      "type": "String",
      "feel": "required",
      "value": "duration(\"PT\" + string(waitTimeMinutes) + \"M\")",
      "binding": {
        "type": "bpmn:TimerEventDefinition#property",
        "name": "timeDuration"
      }
    }
  ]
}
