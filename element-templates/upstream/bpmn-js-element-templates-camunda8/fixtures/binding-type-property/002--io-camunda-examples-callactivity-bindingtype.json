{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Call Activity Template with Binding Type",
  "id": "io.camunda.examples.CallActivity.BindingType",
  "appliesTo": [
    "bpmn:Activity"
  ],
  "category": {
    "name": "With binding type",
    "id": "with-binding-type"
  },
  "elementType": {
    "value": "bpmn:CallActivity"
  },
  "properties": [
    {
      "type": "String",
      "value": "aProcessId",
      "binding": {
        "type": "zeebe:calledElement",
        "property": "processId"
      }
    },
    {
      "type": "Dropdown",
      "label": "Binding",
      "id": "bindingType",
      "binding": {
        "type": "zeebe:calledElement",
        "property": "bindingType"
      },
      "choices": [
        {
          "name": "Latest",
          "value": "latest"
        },
        {
          "name": "Deployment",
          "value": "deployment"
        },
        {
          "name": "Version Tag",
          "value": "versionTag"
        }
      ],
      "value": "deployment"
    },
    {
      "type": "String",
      "label": "Version tag",
      "value": "v1",
      "binding": {
        "type": "zeebe:calledElement",
        "property": "versionTag"
      },
      "condition": {
        "property": "bindingType",
        "equals": "versionTag"
      }
    }
  ]
}
