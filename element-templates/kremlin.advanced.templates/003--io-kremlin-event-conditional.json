{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "id": "io.kremlin.event.conditional",
  "name": "Kremlin Conditional Event",
  "description": "Turns a generic event into an intermediate conditional catch event.",
  "version": 1,
  "engines": {
    "camunda": "^8.6"
  },
  "appliesTo": [
    "bpmn:Event"
  ],
  "elementType": {
    "value": "bpmn:IntermediateCatchEvent",
    "eventDefinition": "bpmn:ConditionalEventDefinition"
  },
  "properties": [
    {
      "label": "Condition Expression",
      "type": "String",
      "value": "= total > threshold",
      "feel": "required",
      "binding": {
        "type": "bpmn:ConditionalEventDefinition#property",
        "name": "condition"
      }
    },
    {
      "label": "Variable Names",
      "type": "String",
      "value": "total,threshold",
      "binding": {
        "type": "bpmn:ConditionalEventDefinition#zeebe:conditionalFilter#property",
        "name": "variableNames"
      }
    },
    {
      "label": "Variable Events",
      "type": "String",
      "value": "create,update",
      "binding": {
        "type": "bpmn:ConditionalEventDefinition#zeebe:conditionalFilter#property",
        "name": "variableEvents"
      }
    }
  ]
}
